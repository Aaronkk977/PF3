{
  "name": "portfolio-performance",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000 --turbopack",
    "dev:clean": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/dev-clean.ps1",
    "dev:open": "powershell -NoProfile -ExecutionPolicy Bypass -File ./start.ps1",
    "build": "next build",
    "build:app": "prisma generate && next build && node scripts/prepare-standalone.mjs",
    "start": "next start",
    "start:prod": "node .next/standalone/server.js",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:repair-datetimes": "tsx scripts/repair-datetimes.ts",
    "db:repair-transaction-dates": "tsx scripts/repair-transaction-dates.ts",
    "db:seed": "tsx prisma/seed.ts",
    "import:legacy": "tsx scripts/import-legacy.ts",
    "accounts:ensure": "tsx scripts/ensure-standard-accounts.ts",
    "import:convert": "tsx scripts/convert-import-files.ts",
    "instruments:sync-currency": "tsx scripts/sync-instrument-currencies.ts",
    "watchlists:migrate": "tsx scripts/apply-watchlist-schema.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.8.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lightweight-charts": "^5.0.7",
    "lucide-react": "^0.511.0",
    "next": "^15.5.18",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "recharts": "^2.15.3",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.3.0",
    "yahoo-finance2": "^2.13.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.1.7",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "eslint": "^9.27.0",
    "eslint-config-next": "^15.5.18",
    "prisma": "^6.8.2",
    "tailwindcss": "^4.1.7",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
