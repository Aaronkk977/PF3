# 開發用（專案目錄內，與 prisma/dev.db 分開）
# DATABASE_URL="file:./dev.db?socket_timeout=60"

# 開發時要看 launch.bat 已輸入的資料，改指到桌面版同一個 DB：
DATABASE_URL="file:C:/Users/User/AppData/Roaming/PortfolioPerformance/data/portfolio.db?socket_timeout=60"

# 正式版由 launcher 注入，不需手動設定：
# APP_RUNTIME=desktop
# APP_DATA_DIR=%APPDATA%\PortfolioPerformance
# DATABASE_URL=file:.../portfolio.db
